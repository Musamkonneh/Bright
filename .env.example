# Supabase Configuration
# Get these values from https://app.supabase.com/project/_/settings/api

# IMPORTANT: Only the ANON_KEY should be exposed in frontend code
# The SERVICE_ROLE_KEY must NEVER be in frontend - use only in backend/scripts
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here

# Edge Function (optional)
SUPABASE_EDGE_CREATE_USER_URL=https://your-project.supabase.co/functions/v1/create-user
